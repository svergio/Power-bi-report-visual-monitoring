# Power BI Multi-Report Monitor - Configuration

# PostgreSQL (db_new.sandbox)
PG_HOST=10.3.0.100
PG_PORT=5432
PG_DATABASE=db_new
PG_USER=dwh_bi_user
PG_PASSWORD=Ojoaidf98$3
PG_SCHEMA=sandbox

# Power BI Authentication
POWERBI_USERNAME=
POWERBI_PASSWORD=
USE_WINDOWS_AUTH=False

# Monitoring
MIN_WORKER_THREADS=1
MAX_WORKER_THREADS=5
PAGE_LOAD_WAIT=10
DEFAULT_THRESHOLD=5.0
SCREENSHOT_WIDTH=1920
SCREENSHOT_HEIGHT=1080

# Quadtree Algorithm (MSE comparison, drill-down to 32px blocks, max 5 levels)
# MSE_THRESHOLD: чем ниже, тем чувствительнее (10.0 для мелких изменений)
DIFF_ENABLED=True
MSE_THRESHOLD=10.0
MIN_BLOCK_SIZE=32
MAX_DEPTH=5

# Paths
SCREENSHOTS_DIR=./Data
LOGS_DIR=./logs
LOG_LEVEL=INFO

