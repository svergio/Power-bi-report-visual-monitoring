# Power BI Report Monitor - Environment Template
# 1) cp .env.example .env
# 2) Fill all values for your environment

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=powerbi_monitor
PG_USER=monitor_user
PG_PASSWORD=change-me
PG_SCHEMA=public
PG_SCHEMA_ALLOWLIST=public,sandbox
PG_POOL_MIN_SIZE=1
PG_POOL_MAX_SIZE=10

# Power BI authentication (optional)
POWERBI_USERNAME=
POWERBI_PASSWORD=
POWERBI_AUTH_SERVER_WHITELIST=

# Runtime
ENV=development
REPORTS_FILE=reports.json
MIN_WORKER_THREADS=1
MAX_WORKER_THREADS=5
PAGE_LOAD_WAIT=10

# Retry/backoff
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=1.0
RETRY_MAX_DELAY_SECONDS=10.0
RETRY_JITTER_SECONDS=0.3

# Diff engine
DIFF_ENABLED=true
MSE_THRESHOLD=10.0
MIN_BLOCK_SIZE=32
MAX_DEPTH=5

# Output and logs
SCREENSHOT_WIDTH=1920
SCREENSHOT_HEIGHT=1080
SCREENSHOTS_DIR=./Data
LOGS_DIR=./logs
LOG_LEVEL=INFO
